---
import educationData from '../data/education.json';
---

<section id="education" class="py-20 px-4 md:px-0 max-w-6xl mx-auto overflow-hidden">
  <div class="container mx-auto  reveal-content" style="animation-delay: 1000ms;">
    <div>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Education
      </h2>
      <p class="text-gray font-body text-sm max-w-md pb-8">
        A summary of academic qualifications / certifications
      </p>
    </div>

    <div class="space-y-8">
      {educationData.map((item, index) => (
        <div class="bg-white/5 border border-white/10 p-4 rounded-2xl">
          <h3 class="text-xl font-heading font-bold text-white mt-1">{item.qualification}</h3>
          <p class="text-gray-400 text-sm mb-2">{item.institution}</p>
          <p class="text-gray-500 font-body text-sm leading-relaxed mb-2">{item.description}</p>
          <div class="flex flex-wrap gap-2">
            {item.skills.map(skill => (
              <span class="px-2 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] text-gray-300">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
